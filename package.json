{
  "name": "better-auth-convex-adapter",
  "version": "1.0.0",
  "description": "Officially integrate Better Auth with Convex — one database for auth and app data",
  "type": "module",
  "main": "./dist/adapter.js",
  "types": "./dist/adapter.d.ts",
  "exports": {
    ".": {
      "import": "./dist/adapter.js",
      "types": "./dist/adapter.d.ts"
    },
    "./convex": {
      "import": "./dist/convex/auth.js",
      "types": "./dist/convex/auth.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "better-auth",
    "convex",
    "auth",
    "adapter",
    "authentication",
    "database",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Qintaris/better-auth-convex-adapter.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "better-auth": ">=1.6.0",
    "convex": ">=1.40.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
